# Caddy reverse proxy — auto HTTPS, one file
# Usage: docker run -d -p 80:80 -p 443:443 -v $PWD/Caddyfile:/etc/caddy/Caddyfile caddy:alpine

llmapi.epichust.com {
    reverse_proxy admin-api:9000
}

llmadmin.epichust.com {
    reverse_proxy admin-web:80
}

llm.epichust.com {
    reverse_proxy gateway:8080
}
